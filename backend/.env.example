# Server
PORT=8081
ALLOWED_ORIGINS=http://localhost:5173

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=your-secure-password

# Database: "memory" or "oracle"
DB_TYPE=memory

# Oracle Autonomous DB (required if DB_TYPE=oracle)
ORACLE_DB_DSN=user="ADMIN" password="your-db-password" connectString="techblogdb_low" libDir="/usr/lib/oracle/19.24/client64/lib"
TNS_ADMIN=/path/to/wallet

# Oracle Object Storage (for image uploads)
OCI_BUCKET_NAME=tech-blog-images
OCI_BUCKET_NAMESPACE=axva0xxfvkwr
OCI_REGION=mx-queretaro-1
